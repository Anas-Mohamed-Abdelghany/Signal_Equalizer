{
    "device": {
      "id": "edge-node-01",
      "name": "Edge Inference Node",
      "description": "Simulated resource-constrained edge device for equalizer deployment",
      "platform": "linux/arm64"
    },
    "compute": {
      "cpu_cores": 2,
      "ram_mb": 512,
      "max_audio_duration_sec": 30,
      "sample_rate": 22050,
      "chunk_size_samples": 4096
    },
    "performance_thresholds": {
      "max_latency_ms": 500,
      "max_memory_mb": 400,
      "max_cpu_percent": 80
    },
    "quantization": {
      "enabled": true,
      "precision": "float32",
      "note": "float16 or int8 can be enabled when targeting embedded MCUs"
    },
    "modes_supported": ["instruments", "voices", "animals", "generic"],
    "ai_inference": {
      "enabled": true,
      "method": "spectral_soft_mask",
      "note": "Lightweight STFT-based separator; no neural network weights required"
    },
    "logging": {
      "level": "INFO",
      "metrics_interval_sec": 5
    }
  }